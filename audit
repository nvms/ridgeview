#!/usr/bin/env bash

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$DIR"

RED="\033[31m"
YELLOW="\033[33m"
GREEN="\033[32m"
DIM="\033[2m"
RESET="\033[0m"
BOLD="\033[1m"
CYAN="\033[36m"

has_issues=0
issues=()
fixes=()

pkg_name="ridgeview"
local_version=$(grep '^version' Cargo.toml | head -1 | sed 's/.*"\(.*\)"/\1/')

echo -e "${BOLD}${pkg_name}${RESET} ${DIM}v${local_version}${RESET}"
echo ""

uncommitted=$(git status --short 2>/dev/null || true)
if [ -n "$uncommitted" ]; then
  staged=$(git diff --cached --name-only 2>/dev/null | wc -l | tr -d ' ')
  unstaged=$(git diff --name-only 2>/dev/null | wc -l | tr -d ' ')
  untracked=$(git ls-files --others --exclude-standard 2>/dev/null | wc -l | tr -d ' ')
  parts=()
  [ "$staged" -gt 0 ] && parts+=("${staged} staged")
  [ "$unstaged" -gt 0 ] && parts+=("${unstaged} modified")
  [ "$untracked" -gt 0 ] && parts+=("${untracked} untracked")
  issues+=("${YELLOW}uncommitted: $(IFS=', '; echo "${parts[*]}")${RESET}")
  fixes+=("${CYAN}git add -A && git commit${RESET}")
  has_issues=1
fi

unpushed=$(git log --oneline @{u}..HEAD 2>/dev/null | wc -l | tr -d ' ')
if [ "$unpushed" -gt 0 ]; then
  issues+=("${YELLOW}${unpushed} unpushed commit(s)${RESET}")
  fixes+=("${CYAN}git push${RESET}")
  has_issues=1
fi

crate_version=$(cargo search "$pkg_name" --limit 1 2>/dev/null | grep "^${pkg_name} " | sed 's/.*= "\(.*\)".*/\1/' || echo "not published")
if [ -z "$crate_version" ]; then
  crate_version="not published"
fi
if [ "$crate_version" = "not published" ]; then
  issues+=("${RED}not published to crates.io${RESET}")
  fixes+=("${CYAN}cargo publish${RESET}")
  has_issues=1
elif [ "$local_version" != "$crate_version" ]; then
  issues+=("${RED}version mismatch: local ${local_version} / crates.io ${crate_version}${RESET}")
  fixes+=("${CYAN}cargo publish${RESET}")
  has_issues=1
fi

if [ -f Cargo.lock ]; then
  lock_check=$(cargo verify-project 2>&1 || true)
  if echo "$lock_check" | grep -q '"success":"false"'; then
    issues+=("${RED}Cargo.lock out of sync${RESET}")
    fixes+=("${CYAN}cargo update${RESET}")
    has_issues=1
  fi
fi

ci_result=$(gh run list --limit 1 --json conclusion,status 2>/dev/null || echo "[]")
ci_conclusion=$(echo "$ci_result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d[0]['conclusion'] if d else 'none')" 2>/dev/null || echo "none")
ci_status=$(echo "$ci_result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d[0]['status'] if d else 'none')" 2>/dev/null || echo "none")
if [ "$ci_status" = "in_progress" ] || [ "$ci_status" = "queued" ]; then
  issues+=("${YELLOW}ci: ${ci_status}${RESET}")
  fixes+=("${CYAN}gh run watch${RESET}")
  has_issues=1
elif [ "$ci_conclusion" = "failure" ]; then
  issues+=("${RED}ci: tests failing${RESET}")
  fixes+=("${CYAN}gh run view --log-failed${RESET}")
  has_issues=1
elif [ "$ci_conclusion" = "none" ]; then
  echo -e "  ${DIM}ci: no runs found${RESET}"
fi

outdated=$(cargo outdated --root-deps-only 2>/dev/null | tail -n +2 | grep -v "^---" || true)
if [ -n "$outdated" ]; then
  dep_count=$(echo "$outdated" | wc -l | tr -d ' ')
  issues+=("${YELLOW}${dep_count} outdated dependency(ies)${RESET}")
  fixes+=("${CYAN}cargo outdated --root-deps-only${RESET}")
  has_issues=1
fi

if [ ${#issues[@]} -eq 0 ]; then
  echo -e "  ${GREEN}ok${RESET} ${DIM}git clean, pushed, crates.io published${RESET}"
  if [ "$ci_conclusion" = "success" ]; then
    echo -e "  ${GREEN}ci: passing${RESET}"
  fi
else
  for i in "${!issues[@]}"; do
    echo -e "  ${issues[$i]}"
    if [ -n "${fixes[$i]:-}" ]; then
      echo -e "    ${fixes[$i]}"
    fi
  done
fi

exit $has_issues
